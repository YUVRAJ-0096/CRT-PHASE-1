Program-1 Single Inheritance?
#include<iostream>
using namespace std;

class Vehicle
{
public:
    void Start()
    {
        cout << "Vehicle Start" << "\n";
    }
};

class Car : public Vehicle
{
public:
    void Drive()
    {
        cout << "Car is running" << "\n";
    }
};

int main()
{
    Car obj1;
    obj1.Start();
    obj1.Drive();

    return 0;
}

Program-2 Multilevel Inheritance?
#include<iostream>
using namespace std;

class Vehicle
{
public:
    void Start()
    {
        cout << "Vehicle Start" << "\n";
    }
};

class Car : public Vehicle
{
public:
    void Drive()
    {
        cout << "Car is running" << "\n";
    }
};

class Speedometer : public Car
{
public:
    void Speed()
    {
        cout << "Car is running at the speed of 100" << "\n";
    }
};

int main()
{
    Speedometer obj1;

    obj1.Start();
    obj1.Drive();
    obj1.Speed();

    return 0;
}

