Program-6 Print Hollow Square of any number?
#include<iostream>
using namespace std;
int main(){
    int n;
    cout<<"Enter size"; // for size of square
    cin>>n;
    
    for(int i=1; i<=n; i++) //  for outer column 
    {
        for(int j=1; j<=n; j++) // for inner column
        {
           if(i==1 || i==n|| j==1 || j==n) // logic,condition 
           cout<<"*";  // star
           else
           cout<<" "; // space
        }
        cout<<endl;
    }
return 0;
}


