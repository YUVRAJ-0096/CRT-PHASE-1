Progran-6  Factorial of number?
#include<iostream>
using namespace std;

int main() {
    int n;
    cin >> n;
    int fact = 1;

    for(int i = 1; i <= n; i++) {
        fact = fact * i;
    }

    cout << "Factorial = " << fact;

    return 0;
}

Program-7 Prime number checker?
#include<iostream>
using namespace std;
int main(){
    int n;
    cin >> n;
    
    bool isPrime = true;
    if(n <2){
        isPrime = false;
    }else{
        for(int i = 2; i<n; i++)
        if(n % i ==0){
            isPrime = false;
            break;
        }
    }
    }
    if(isPrime)
    {
        cout<<"it is a prime number";
    }else{
        cout<<"it is not a prime number";
        return 0;
    }
    }
}

