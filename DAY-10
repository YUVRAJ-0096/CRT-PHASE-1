Program-3 Sum of elements of 2-D array?
#include<iostream>
using namespace std;
int main() {
	int arr [2][2];
	int sum = 0;
	
	for(int i = 0; i < 2; i++){
	    for(int j = 0; j < 2; j++){
	        cin >> arr[i][j];
	        sum = sum + arr[i][j];
	    }
	}
	cout << sum;
}

Program-4 Search an element in a 2-D Array?
#include<iostream>
using namespace std;
int main() {
	int arr [2][2] = {{10,29},
		{30,40}
	};

	int searchelement;
    cin >> searchelement;

	for(int i = 0; i < 2; i++) {
		for(int j = 0; j < 2; j++) {
			if(arr[i][j] == searchelement) {
				cout << i << " "<< j;
				return 0;
			}
		}
	}
	cout << "element not found";
}




