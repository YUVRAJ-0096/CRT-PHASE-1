Program-7 Encapsulation
#include<iostream>
using namespace std;

class BankAccount {
private:
    int BankBalance;

public:
    
    void setBalance(int amount) {
        if(amount >= 0) {
            BankBalance = amount;
        } else {
            cout << "Enter a valid number";
        }
    }

    
    int getBalance() {
        return BankBalance;
    }
};

int main() {
    BankAccount obj1;

    obj1.setBalance(8000);

    cout << obj1.getBalance();

    return 0;
}




