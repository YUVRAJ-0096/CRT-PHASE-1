Program-2 Else statement?
#include<iostream>

using namespace std;

int main(){
    int age;
    cin >> age;

    if(age >= 18){
        cout << "Eligible for vote";
    } else {
        cout << "Not Eligible for vote";
    }

    return 0;
}


Program-3 Nested if-else statement?
#include<iostream>

using namespace std;

int main()
{
    int age;
    cin >> age;

    if(age >= 18)
    {
        if(age >= 50)
        {
            cout << "Senior citizen eligible for vote";
        }
        else
        {
            cout << "Eligible for vote";
        }
    }
    else
    {
        if(age < 0)
        {
            cout << "Enter a valid age number";
        }
        else
        {
            cout << "Not Eligible for vote";
        }
    }

    return 0;
}


Program-4 Ternary operator?
#include<iostream>

using namespace std;

int main(){ 
    int a, b;
    int max_number;

    cout << "Enter 1st number: ";
    cin >> a;

    cout << "Enter 2nd number: ";
    cin >> b;

    max_number = (a > b) ? a : b;

    cout << "Maximum number is: " << max_number;

    return 0;
}



