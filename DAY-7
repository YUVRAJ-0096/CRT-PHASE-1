Program-1 Call By Value & Call By Reference?

#include<iostream>
using namespace std;

void updatebyValue(int a) {
	a = 900;
}

void updateByRefrenece(int &a) {
	a = 900;
}

int main() {
	int original = 700;
	updatebyValue(original);
	cout << original <<"\n";
	updateByRefrenece(original);
	cout << original;
	
	return 0;
}


